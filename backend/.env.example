# Anthropic API key for vision and LLM calls
ANTHROPIC_API_KEY=

# Database connection (Phase 1+)
DATABASE_URL=postgresql://cooksense:cooksense@localhost:5432/cooksense

# ChromaDB connection (Phase 1+)
# Leave CHROMA_HOST empty to use embedded persistent client (dev default).
# Set host + token to use ChromaDB Cloud (prod).
CHROMA_HOST=
CHROMA_API_KEY=
CHROMA_PERSIST_DIR=./data/.chroma

# Translation cache directory (Phase 1+)
TRANSLATION_CACHE_DIR=./data/translations

# Embedding model used by recipe repository (multilingual)
EMBEDDING_MODEL=sentence-transformers/distiluse-base-multilingual-cased-v2

# CORS — adjust for production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
